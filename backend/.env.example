# Copy this file to `.env` and fill in real values.
# Do NOT commit `.env` to git.

# Database — for local dev, SQLite is easiest.
# For production, use Postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./finance.db

# JWT — generate a secure secret with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — frontend URLs allowed to call this API
FRONTEND_ORIGIN=http://localhost:3000
